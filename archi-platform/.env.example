# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/archi_platform?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# OAuth (optionnel)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Storage (S3-compatible). Laisser vide pour utiliser le filesystem local en dev.
STORAGE_DRIVER="local"             # "local" | "s3"
STORAGE_LOCAL_PATH="./storage/local"
S3_ENDPOINT=""                     # ex: https://<account>.r2.cloudflarestorage.com
S3_REGION="auto"
S3_BUCKET="archi-platform"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""                   # base URL publique si bucket public, sinon utilisé pour signed URLs

# Email
RESEND_API_KEY=""
EMAIL_FROM="Archi Platform <noreply@example.com>"
EMAIL_DRIVER="console"             # "console" en dev, "resend" en prod

# App
APP_URL="http://localhost:3000"
